// ── 4. NEW models — coupons (no conflict with existing schema) ─────────────
model Coupon {
  id                String             @id @default(cuid())
  code              String             @unique
  discountType      DiscountType
  value             Int                // PERCENT: whole % | FLAT: rupees
  maxDiscountRs     Int?               // cap for PERCENT
  minOrderRs        Int?
  appliesTo         String             @default("ALL") // ALL | DIGITAL | PHYSICAL | plan slug
  firstOrderOnly    Boolean            @default(false)
  usageLimitGlobal  Int?
  usageLimitPerUser Int?               @default(1)
  validFrom         DateTime?
  validUntil        DateTime?
  stackable         Boolean            @default(false)
  source            CouponSource       @default(MANUAL)
  isActive          Boolean            @default(true)
  redemptions       CouponRedemption[]
  createdAt         DateTime           @default(now())

  @@map("coupons")
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String   // scalar (no back-relation needed on User)
  orderId   String
  amountRs  Int
  createdAt DateTime @default(now())

  @@index([couponId, userId])
  @@map("coupon_redemptions")
}

enum DiscountType {
  PERCENT
  FLAT
  FREE_DELIVERY
}

enum CouponSource {
  MANUAL
  REFERRAL
  CART_RECOVERY
  LOYALTY
}

