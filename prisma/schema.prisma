// ============================================================
// FITFUEL — PRISMA SCHEMA v6.1 (Phase 9 — Recipe + Plan System)
// UPDATED: May 20, 2026 — Fixes 4 critical gaps from v6.0
//
// CHANGES IN THIS VERSION:
// 1. FoodEntry + MealLog: bidirectional relation (mealLogId back-ref)
// 2. MealPlan + MealPlanProduct: bridge relation + MealPlan.planPrices
// 3. PlanPrice: dual-link (productId legacy + mealPlanId new)
// 4. UserActivePlan: order relation + duration/mealsPerDay fields
// 5. Order: userActivePlans back-relation
//
// MIGRATION NAME: fix-phase9-relations-and-pricing-bridge
// Run: npx prisma migrate dev --name fix-phase9-relations-and-pricing-bridge
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  CUSTOMER
  ADMIN
  OWNER
  KITCHEN
  DISPATCH
}

enum DietType {
  VEGETARIAN
  EGGETARIAN
  NON_VEGETARIAN
}

enum MealPlanType {
  // ── Phase 3 — Core (live at launch) ──
  MUSCLE_GAIN
  WEIGHT_LOSS
  BALANCED_DIET
  OFFICE_EMPLOYEE
  JAIN_DIET
  // ── Phase 9 — Lifestyle & Medical (coming soon) ──
  HEALTHY_SEX_LIFESTYLE
  ALCOHOL_RECOVERY
  SMOKING_RECOVERY
  DIABETES_MANAGEMENT
  PCOS_HORMONAL_BALANCE
  THYROID_SUPPORT
  HYPERTENSION_DASH
  POST_SURGERY_RECOVERY
  MENTAL_HEALTH_STRESS
  GUT_HEALTH_IBS
  ANTI_AGING_LONGEVITY
  CUSTOM_PERSONALIZED
}

enum PlanDuration {
  TRIAL_DAY
  WEEKLY
  BI_WEEKLY
  MONTHLY_EXCL_WEEKENDS
  ONE_MONTH
  TWO_MONTH
  THREE_MONTH
}

enum MealsPerDay {
  BREAKFAST_LUNCH
  SNACK_DINNER
  ALL_FOUR
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_FAILED
  CONFIRMED
  PROCESSING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  PAYU
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  PREPARING
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED_DELIVERY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ActivityLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
  EXTREMELY_ACTIVE
}

enum FitnessGoal {
  LOSE_WEIGHT
  GAIN_MUSCLE
  MAINTAIN
  IMPROVE_FITNESS
  MANAGE_CONDITION
}

// ── Phase 9 — New Enums ──

enum MealSlot {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum PlanTier {
  STANDARD
  PREMIUM
  LUXURY
}

enum PlanCategory {
  STANDARD
  LIFESTYLE_MEDICAL
  SPORTS
  CORPORATE
  DIGITAL
}

enum DietVariant {
  VEG
  EGG
  NON_VEG
  JAIN
  VEGAN
}

enum DeliveryWindow {
  MORNING
  EVENING
}

// ============================================================
// USER
// ============================================================

model User {
  id            String    @id @default(cuid())
  phone         String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  avatarUrl     String?
  role          Role      @default(CUSTOMER)
  isActive      Boolean   @default(true)
  referralCode  String?   @unique // generated on signup
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  notificationPreference NotificationPreference?

  profile     UserProfile?
  addresses   Address[]
  orders      Order[]
  bodyMetrics BodyMetric[]
  activePlans ActivePlan[]
  accounts    Account[]
  sessions    Session[]
  supplementClicks       SupplementClick[]

  // ── Phase 6 — Nutrition Tracker ──
  foodItems     FoodItem[]
  foodEntries   FoodEntry[]
  nutritionGoal NutritionGoal?
  waterLogs     WaterLog[]

  // ── Phase 7 — Exercise Library ──
  workoutSessions WorkoutSession[]

  // ── Phase 9 — Plan System ──
  userActivePlans UserActivePlan[]
  mealLogs        MealLog[]

  consistencySnapshots ConsistencySnapshot[]

  @@map("users")

// Phase 17A — partner system
  referredByPartnerCode    String?            @db.VarChar(64)
  creditsBalanceRs         Int                @default(0)
  ownedPartner             Partner?           @relation("PartnerOwner")
  referralsAsReferee       PartnerReferral[]  @relation("ReferralReferee")
  creditLedger             CreditLedger[]     @relation("UserCredits")

}

model UserProfile {
  id             String         @id @default(cuid())
  userId         String         @unique
  dateOfBirth    DateTime?
  gender         Gender?
  heightCm       Float?
  weightKg       Float?
  activityLevel  ActivityLevel?
  fitnessGoal    FitnessGoal?
  dietPreference DietType?
  medicalNotes   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // ── Phase 9 — Onboarding + Personalisation fields ──
  targetWeightKg      Float?
  age                 Int?
  healthConditions    String[] // pcos, diabetic, thyroid, heart, etc.
  dietaryRestrictions String[] // no_pork, no_beef, nut_allergy, etc.
  allergies           String[] // nuts, dairy, gluten, shellfish
  tdee                Int? // computed + stored after onboarding
  calorieTarget       Int? // personalised target (= TDEE ± goal adjustment)
  onboardingComplete  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  weeklyConsistencyScore Int? // 0-100, recomputed every Sunday — feeds AI trainer
  referredBy             String? // userId of referrer

  @@map("user_profiles")
}

// ============================================================
// ADDRESS
// ============================================================

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  line1     String
  line2     String?
  area      String
  city      String   @default("Pune")
  pincode   String
  landmark  String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ============================================================
// MEAL PLAN PRODUCT (catalogue — Phase 3, preserved)
// DEPRECATED: Migrate checkout to MealPlan + PlanPrice directly.
// Kept for backward compatibility during transition.
// ============================================================

model MealPlanProduct {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  planType    MealPlanType
  description String?
  imageUrl    String?
  isActive    Boolean      @default(true)
  isLive      Boolean      @default(false)
  phase       Int          @default(3)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  pricing     PlanPrice[]
  orderItems  OrderItem[]
  activePlans ActivePlan[]
  mealPlans   MealPlan[] // ← NEW: bridge to Phase 9 MealPlan

  @@map("meal_plan_products")
}

// ============================================================
// PRICE TABLE
// ============================================================
// Dual-link: productId = legacy (MealPlanProduct), mealPlanId = new (MealPlan)
// During transition, populate both. Eventually drop productId + diet fields.
// ============================================================

model PlanPrice {
  id String @id @default(cuid())

  // Legacy link — MealPlanProduct (Phase 3)
  productId String?
  product   MealPlanProduct? @relation(fields: [productId], references: [id], onDelete: Cascade)

  // New link — MealPlan (Phase 9, 103 variants)
  mealPlanId String?
  mealPlan   MealPlan? @relation(fields: [mealPlanId], references: [id])

  diet        DietType
  duration    PlanDuration
  mealsPerDay MealsPerDay
  priceRs     Int
  gstPercent  Int          @default(5)
  isActive    Boolean      @default(true)

  mrpRs               Int?
  priceIsTaxInclusive Boolean @default(false)
  isDigital           Boolean @default(false)

  bundle DigitalBundle @default(STARTER)

  @@unique([productId, diet, duration, mealsPerDay])

  @@unique([mealPlanId, duration, mealsPerDay, bundle, isDigital])
  @@map("plan_prices")
}

// Phase 19A — Premium/Luxury tier waitlist signups from /plans
model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String
  tier      String   // "PREMIUM" | "LUXURY"
  source    String?  // "plans_page", etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, tier])
  @@index([tier])
  @@map("waitlist_signups")
}

// ============================================================
// ORDER
// ============================================================

model Order {
  id            String        @id @default(cuid())
  userId        String
  addressId     String?
  orderNumber   String        @unique
  status        OrderStatus   @default(PENDING_PAYMENT)
  subtotalRs    Int
  gstRs         Int
  totalRs       Int
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  payuTxnId     String?
  payuPaymentId String?
  notes         String?
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  address         Address?         @relation(fields: [addressId], references: [id])
  items           OrderItem[]
  deliveries      Delivery[]
  payment         Payment?
  userActivePlans UserActivePlan[] // ← NEW: link to active plan record

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  mrpSubtotalRs  Int?
  discountRs     Int     @default(0)
  couponCode     String?
  cgstRs         Int     @default(0)
  sgstRs         Int     @default(0)
  igstRs         Int     @default(0)
  buyerStateCode String?
  hsnSacCode     String?

  @@map("orders")

  // Phase 17A — referral attribution snapshot
  referralAttribution      String?
  creditAppliedRs          Int                @default(0)
  referralUsage            PartnerReferral[]  @relation("ReferralOrder")
}

model OrderItem {
  id          String       @id @default(cuid())
  orderId     String
  productId   String?
  diet        DietType
  duration    PlanDuration
  mealsPerDay MealsPerDay
  priceRs     Int
  gstRs       Int
  totalRs     Int
  quantity    Int          @default(1)

  order   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product MealPlanProduct? @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ============================================================
// PAYMENT
// ============================================================

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amountRs      Int
  payuTxnId     String?
  payuPaymentId String?
  payuHash      String?
  rawResponse   Json?
  failureReason String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ============================================================
// DELIVERY
// ============================================================

model Delivery {
  id             String          @id @default(cuid())
  orderId        String
  deliveryDate   DateTime
  status         DeliveryStatus  @default(PREPARING)
  mealsIncluded  String[]
  driverName     String?
  driverPhone    String?
  trackingNotes  String?
  deliveredAt    DateTime?
  dispatchNotifiedAt   DateTime?
  deliveryWindow DeliveryWindow?

  // ── Phase 10 — driver assignment + customer confirmation ──
  assignedDriverId    String?
  customerConfirmedAt DateTime? // customer tapped "Yes, received"
  customerIssueNote   String? // set when customer reports a problem

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver Driver? @relation(fields: [assignedDriverId], references: [id])

  @@index([orderId])
  @@index([deliveryDate])
  @@index([assignedDriverId])
  @@map("deliveries")
}

model ConsistencySnapshot {
  id             String   @id @default(cuid())
  userId         String
  weekStart      DateTime @db.Date
  score          Int
  label          String
  mealsPoints    Int      @default(0)
  workoutsPoints Int      @default(0)
  waterPoints    Int      @default(0)
  weighInPoints  Int      @default(0)
  noSkipPoints   Int      @default(0)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
  @@map("consistency_snapshots")
}

// ── Phase 10 — delivery drivers (tokenized-link access; franchiseId reserved for franchise model) ──
model Driver {
  id          String   @id @default(cuid())
  name        String
  phone       String
  accessToken String   @unique // tokenized-link auth — opens /driver/[accessToken]
  isActive    Boolean  @default(true)
  franchiseId String? // null = main Pune kitchen; set per-franchise later
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deliveries Delivery[]

  @@index([accessToken])
  @@index([franchiseId])
  @@map("drivers")
}

// ============================================================
// ACTIVE PLAN (Phase 3 — DEPRECATED)
// ============================================================
// Kept for backward compatibility. Migrate existing rows to
// UserActivePlan, then drop this table in a future migration.
// ============================================================

model ActivePlan {
  id          String       @id @default(cuid())
  userId      String
  productId   String
  diet        DietType
  duration    PlanDuration
  mealsPerDay MealsPerDay
  startDate   DateTime
  endDate     DateTime
  isPaused    Boolean      @default(false)
  pausedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user    User            @relation(fields: [userId], references: [id])
  product MealPlanProduct @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([endDate])
  @@map("active_plans")
}

// ============================================================
// BODY METRICS
// ============================================================

model BodyMetric {
  id           String   @id @default(cuid())
  userId       String
  measuredAt   DateTime @default(now())
  weightKg     Float?
  bmi          Float?
  bodyFatPct   Float?
  muscleMassKg Float?
  waterPct     Float?
  boneMassKg   Float?
  visceralFat  Float?
  metabolicAge Int?
  proteinPct   Float?
  source       String   @default("manual")
  notes        String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([measuredAt])
  @@map("body_metrics")
}

// ============================================================
// PHASE 7 — EXERCISE LIBRARY
// ============================================================

model Exercise {
  id               String   @id
  name             String
  category         String
  level            String
  force            String?
  mechanic         String?
  equipment        String?
  primaryMuscles   String[]
  secondaryMuscles String[]
  instructions     String[]
  images           String[]
  modality         String  @default("strength") // strength | cardio | hiit | calisthenics | mobility | sport
  met              Float   @default(4.0)         // real metabolic equivalent
  progressionGroup String? // skill-chain id (e.g. "pushup") for calisthenics progressions
  progressionLevel Int?    // 1..n position within the chain


  workoutExercises WorkoutExercise[]

  @@index([category])
  @@index([level])
  @@index([equipment])
  @@index([modality])
  @@map("exercises")
}

model WorkoutSession {
  id             String    @id @default(cuid())
  userId         String
  name           String?
  date           DateTime  @db.Date
  startedAt      DateTime?
  completedAt    DateTime?
  durationMins   Int?
  caloriesBurned Int?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]

  @@index([userId, date])
  @@map("workout_sessions")
}

model WorkoutExercise {
  id               String  @id @default(cuid())
  workoutSessionId String
  exerciseId       String
  orderInSession   Int
  notes            String?

  workoutSession WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exercise       Exercise       @relation(fields: [exerciseId], references: [id])
  sets           WorkoutSet[]

  @@map("workout_exercises")
}

model WorkoutSet {
  id                String  @id @default(cuid())
  workoutExerciseId String
  setNumber         Int
  reps              Int?
  weightKg          Float?
  durationSecs      Int?
  distanceM         Float?
  completed         Boolean @default(false)
  notes             String?

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@map("workout_sets")
}

// ============================================================
// ADMIN NOTES
// ============================================================

model AdminNote {
  id        String   @id @default(cuid())
  userId    String
  authorId  String
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("admin_notes")
}

// ============================================================
// NEXTAUTH
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================================
// PHASE 6 — NUTRITION TRACKER
// ============================================================

model MealType {
  id        String      @id @default(cuid())
  name      String      @unique
  emoji     String?
  sortOrder Int         @default(0)
  entries   FoodEntry[]

  @@map("meal_types")
}

model FoodItem {
  id             String   @id @default(cuid())
  name           String
  brand          String?
  category       String?
  per100Calories Float
  per100Protein  Float    @default(0)
  per100Carbs    Float    @default(0)
  per100Fat      Float    @default(0)
  per100Fiber    Float    @default(0)
  isCustom       Boolean  @default(false)
  userId         String?
  createdAt      DateTime @default(now())

  entries FoodEntry[]
  user    User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Phase 9 — Recipe system back-relation ──
  recipeIngredients RecipeIngredient[]

  @@index([name])
  @@map("food_items")
}

model FoodEntry {
  id         String   @id @default(cuid())
  userId     String
  foodItemId String
  mealTypeId String
  entryDate  DateTime @db.Date
  quantity   Float
  calories   Float
  protein    Float
  carbs      Float
  fat        Float
  fiber      Float    @default(0)
  notes      String?
  createdAt  DateTime @default(now())

  // ── Phase 9 FIX: back-reference to MealLog ──
  // null = manually logged entry; set = auto-created from MealLog confirmation
  mealLogId String?  @unique
  mealLog   MealLog? @relation(fields: [mealLogId], references: [id])

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItem FoodItem @relation(fields: [foodItemId], references: [id])
  mealType MealType @relation(fields: [mealTypeId], references: [id])

  @@index([userId, entryDate])
  @@map("food_entries")
}

model NutritionGoal {
  id        String   @id @default(cuid())
  userId    String   @unique
  calories  Float    @default(2000)
  protein   Float    @default(150)
  carbs     Float    @default(250)
  fat       Float    @default(67)
  fiber     Int      @default(28)
  waterMl   Int      @default(2500)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("nutrition_goals")
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  entryDate DateTime @db.Date
  amountMl  Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryDate])
  @@map("water_logs")
}

// ============================================================
// PHASE 9A — RECIPE DATABASE
// ============================================================

// Core unit of the platform. Every meal, every plan, every PDF, every SOP.
model Recipe {
  id               String     @id @default(cuid())
  name             String
  slug             String     @unique
  description      String
  shortDescription String // one-line tagline for cards
  cuisineType      String // NorthIndian, SouthIndian, Continental, etc.
  mealType         MealSlot // BREAKFAST, LUNCH, DINNER, SNACK
  dietaryTags      String[] // VEG, EGG, NON_VEG, JAIN, VEGAN
  planCategories   String[] // weight_loss, pcos, diabetic, sports_strength, etc.
  tierAvailability PlanTier[] // STANDARD, PREMIUM, LUXURY
  servingSizeGrams Int // canonical serving size in grams
  prepTimeMins     Int
  cookTimeMins     Int
  difficulty       String // easy, medium, hard
  equipmentNeeded  String[]
  allergens        String[]
  shelfLifeHours   Int // how long after cooking
  packagingType    String // box, container, pouch
  kitchenStation   String // hot_kitchen, cold_prep, assembly
  costPerServing   Decimal? // ingredient cost — for margin tracking
  seasonTags       String[] // monsoon, summer, winter, all_year
  rotationGroup    Int // 1-60 — ensures no repeat in 60-day cycle
  imageUrl         String?
  videoUrl         String?
  isActive         Boolean    @default(true)
  isFeatured       Boolean    @default(false)
  swapAwayCount    Int        @default(0) // incremented on meal swap request
  avgRating        Float? // recomputed from MealLog ratings

  // Macros — per canonical serving
  caloriesPerServing Int
  proteinGrams       Decimal
  carbsGrams         Decimal
  fatGrams           Decimal
  fibreGrams         Decimal

  // Macros — per 100g (computed + stored for fast lookup)
  caloriesPer100g Int
  proteinPer100g  Decimal
  carbsPer100g    Decimal
  fatPer100g      Decimal
  fibrePer100g    Decimal

  // Micronutrients per serving — key ones for medical plans
  ironMg          Decimal?
  calciumMg       Decimal?
  vitaminDMcg     Decimal?
  vitaminCMg      Decimal?
  vitaminB12Mcg   Decimal?
  folateMcg       Decimal?
  sodiumMg        Decimal?
  potassiumMg     Decimal?
  omegaThreeGrams Decimal?
  zincMg          Decimal?
  magnesiumMg     Decimal?
  seleniumMcg     Decimal?
  glycaemicIndex  Int? // critical for diabetic + PCOS plans

  ingredients   RecipeIngredient[]
  steps         RecipeStep[]
  scheduleSlots PlanScheduleSlot[]
  mealLogs      MealLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mealType])
  @@index([rotationGroup])
  @@map("recipes")
}

// Links a recipe to a food_item. Quantities in raw grams.
model RecipeIngredient {
  id                 String  @id @default(cuid())
  recipeId           String
  foodItemId         String
  quantityGrams      Decimal // raw weight before cooking
  cookedWeightFactor Decimal @default(1.0) // cooked/raw ratio — rice: 2.5, chicken: 0.75
  prepNote           String? // "soaked overnight", "finely chopped", "boiled"
  isOptional         Boolean @default(false)
  substituteFor      String? // ingredient id this can replace
  orderInRecipe      Int

  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  foodItem FoodItem @relation(fields: [foodItemId], references: [id])

  @@map("recipe_ingredients")
}

// Step-by-step SOP — scales to franchise kitchen.
model RecipeStep {
  id           String  @id @default(cuid())
  recipeId     String
  stepNumber   Int
  title        String // "Marinate the chicken"
  instruction  String // full instruction text
  durationMins Int?
  temperatureC Int? // for baking/cooking temp
  technique    String? // "saute", "steam", "grill", "blend"
  kitchenNote  String? // note for kitchen staff only
  imageUrl     String?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_steps")
}

// ============================================================
// PHASE 9A — MEAL PLAN SYSTEM
// ============================================================

// Plan definition — the full catalogue of FitFuel plans.
model MealPlan {
  id                String       @id @default(cuid())
  name              String
  slug              String       @unique
  category          PlanCategory // STANDARD, LIFESTYLE_MEDICAL, SPORTS
  subCategory       String // weight_loss, pcos, diabetic, strength, etc.
  displayName       String // "Weight Loss — Non Vegetarian"
  tagline           String
  description       String
  longDescription   String // full sales page description
  whoIsItFor        String // target customer description
  keyPrinciples     String[] // nutritional principles bullet points
  whatIsAvoided     String[] // excluded ingredients / foods
  dietaryVariant    DietVariant // VEG, EGG, NON_VEG, JAIN, VEGAN
  tier              PlanTier // STANDARD, PREMIUM, LUXURY
  avgCaloriesPerDay Int
  avgProteinGrams   Int
  avgCarbsGrams     Int
  avgFatGrams       Int
  cycleLengthDays   Int          @default(30) // 30-day no-repeat
  mealsPerDay       Int          @default(4) // B+L+D+S
  nutritionistName  String?
  nutritionistCred  String? // "MSc Nutrition, RD"
  nutritionistBio   String?
  medicalDisclaimer String? // for lifestyle / medical plans
  isActive          Boolean      @default(false) // flip to true when ready to sell
  isFeatured        Boolean      @default(false)
  sortOrder         Int          @default(0)
  imageUrl          String?
  accentColor       String? // hex — for plan page theming

  // Links to legacy pricing (MealPlanProduct) for checkout compatibility
  productId String?
  product   MealPlanProduct? @relation(fields: [productId], references: [id])

  scheduleSlots   PlanScheduleSlot[]
  userActivePlans UserActivePlan[]
  planPrices      PlanPrice[] // ← NEW: direct pricing links

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([subCategory])
  @@map("meal_plans")
}

// 30-day rotating schedule. Day → Meal Slot → Recipe.
model PlanScheduleSlot {
  id                String   @id @default(cuid())
  mealPlanId        String
  dayNumber         Int // 1–60
  mealSlot          MealSlot // BREAKFAST, LUNCH, DINNER, SNACK
  recipeId          String
  servingMultiplier Decimal  @default(1.0) // adjust portion for this slot

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation(fields: [recipeId], references: [id])

  @@unique([mealPlanId, dayNumber, mealSlot])
  @@index([mealPlanId, dayNumber])
  @@map("plan_schedule_slots")
}

// Tracks which plan a user is on and which day they're currently on.
model UserActivePlan {
  id             String         @id @default(cuid())
  userId         String
  mealPlanId     String
  orderId        String?
  startDate      DateTime
  endDate        DateTime
  currentDay     Int            @default(1) // auto-increments daily
  status         String         @default("active") // active, paused, completed, cancelled
  pausedUntil    DateTime?
  skipDates      DateTime[] // dates user skipped delivery
  calorieTarget  Int? // personalised — overrides plan default
  proteinTarget  Int?
  carbTarget     Int?
  fatTarget      Int?
  deliveryWindow DeliveryWindow @default(MORNING)

  // ── NEW: denormalised from Order for fast dashboard queries ──
  duration    PlanDuration?
  mealsPerDay MealsPerDay?

  // ── NEW: proper relation to Order ──
  order Order? @relation(fields: [orderId], references: [id])

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealPlan MealPlan  @relation(fields: [mealPlanId], references: [id])
  mealLogs MealLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([endDate])
  isDigital Boolean @default(false)

  bundle DigitalBundle @default(STARTER)

  @@map("user_active_plans")
}

// Did the user eat today's planned meal? Links plan → nutrition tracker.
model MealLog {
  id               String    @id @default(cuid())
  userId           String
  userActivePlanId String
  recipeId         String
  mealSlot         MealSlot
  logDate          DateTime  @db.Date
  plannedGrams     Int // what the plan prescribed
  actualGrams      Int? // what user actually ate (adjusted)
  confirmedAt      DateTime? // when user tapped "I ate this"
  skipped          Boolean   @default(false)
  rating           Int? // 1-5 meal feedback
  ratingNote       String?

  // ── Phase 9 FIX: bidirectional relation to FoodEntry ──
  // MealLog creates FoodEntry → FoodEntry stores mealLogId as back-reference
  foodEntry FoodEntry?

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  activePlan UserActivePlan @relation(fields: [userActivePlanId], references: [id])
  recipe     Recipe         @relation(fields: [recipeId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, logDate])
  @@index([userActivePlanId])
  @@map("meal_logs")
}

// ============================================================
// PHASE 9D — EXERCISE SCHEDULE (linked to plan categories)
// ============================================================

// Workout program linked to a meal plan type / category.
model ExerciseSchedule {
  id                  String   @id @default(cuid())
  mealPlanCategory    String // weight_loss, muscle_gain, pcos, etc.
  tier                PlanTier
  name                String // "Weight Loss 5-Day Program"
  description         String
  weeklyStructure     Json // { mon: ["chest", "triceps"], tue: ["cardio"], ... }
  daysPerWeek         Int
  sessionDurationMins Int

  workoutDays ExerciseScheduleDay[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mealPlanCategory])
  @@map("exercise_schedules")
}

model ExerciseScheduleDay {
  id                String  @id @default(cuid())
  scheduleId        String
  dayOfWeek         String // monday, tuesday, ... or rest
  focusArea         String // "Upper body strength", "LISS Cardio", "Rest + Mobility"
  exercises         Json // [{ exerciseId, sets, reps, restSecs, notes }]
  estimatedCalories Int
  isRestDay         Boolean @default(false)

  schedule ExerciseSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@map("exercise_schedule_days")
}

enum DiscountType {
  PERCENT
  FLAT
  FREE_DELIVERY
}

enum CouponSource {
  MANUAL
  REFERRAL
  CART_RECOVERY
  LOYALTY
}

enum AffiliateNetwork {
  NUTRABAY
  HEALTHKART
  MUSCLEBLAZE
  AMAZON_IN
  FLIPKART
  TATA_1MG
  WELLNESS_FOREVER
  OTHER
}

enum SupplementGoal {
  MUSCLE_GAIN
  WEIGHT_LOSS
  BALANCED
  PERFORMANCE
}

model Coupon {
  id                String             @id @default(cuid())
  code              String             @unique
  discountType      DiscountType
  value             Int
  maxDiscountRs     Int?
  minOrderRs        Int?
  appliesTo         String             @default("ALL")
  firstOrderOnly    Boolean            @default(false)
  usageLimitGlobal  Int?
  usageLimitPerUser Int?               @default(1)
  validFrom         DateTime?
  validUntil        DateTime?
  stackable         Boolean            @default(false)
  source            CouponSource       @default(MANUAL)
  isActive          Boolean            @default(true)
  redemptions       CouponRedemption[]
  createdAt         DateTime           @default(now())

  @@map("coupons")
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  orderId   String
  amountRs  Int
  createdAt DateTime @default(now())

  @@index([couponId, userId])
  @@map("coupon_redemptions")
}
 
enum DigitalBundle {
  STARTER
  PRO
}

// ============================================================
// PHASE 14 — BLOG / FAQ / TESTIMONIALS (added Jun 8, 2026)
// Public content surfaces. Managed by Phase 15 Admin Panel later.
// Added via `npx prisma db push` (NEVER migrate dev — Decision #71).
// ============================================================

enum BlogStatus {
  DRAFT
  PUBLISHED
}

model BlogPost {
  id            String     @id @default(cuid())
  slug          String     @unique
  title         String
  excerpt       String // card teaser + meta description
  contentHtml   String // owner-authored HTML body (Phase 15 admin → rich text)
  coverImageUrl String?
  category      String // Nutrition, Training, Recipes, FitFuel News, Guides
  tags          String[]
  authorName    String     @default("Team FitFuel")
  readMinutes   Int        @default(5)
  status        BlogStatus @default(PUBLISHED)
  isFeatured    Boolean    @default(false)
  publishedAt   DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status, publishedAt])
  @@index([category])
  @@map("blog_posts")
}

model Faq {
  id        String   @id @default(cuid())
  category  String // Delivery & Areas, Plans & Menu, Tracking, Dietary & Allergens, Pricing & Payment, Account
  question  String
  answerHtml String // light HTML — allows inline links to legal pages
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, sortOrder])
  @@map("faqs")
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  location    String // Kharadi, Viman Nagar, Kalyani Nagar...
  planLabel   String // "Weight Loss · 1 Month"
  goal        String? // weight_loss, muscle_gain, balanced, office
  resultLabel String // "-4kg in 15 days"
  rating      Int      @default(5)
  quote       String
  avatarUrl   String?
  isFeatured  Boolean  @default(false) // surfaced on homepage / featured row
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([isActive, sortOrder])
  @@map("testimonials")
}
enum NotificationChannel {
  WHATSAPP
  EMAIL
  BOTH
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

model NotificationTemplate {
  id                   String              @id @default(cuid())
  key                  String              @unique
  name                 String
  description          String?
  channel              NotificationChannel
  category             String

  whatsappTemplateName String?
  whatsappLanguage     String?             @default("en")
  whatsappVariables    String?

  emailSubject         String?
  emailBody            String?

  active               Boolean             @default(true)
  isStaff              Boolean             @default(false)

  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@map("notification_templates")
}

model NotificationLog {
  id           String              @id @default(cuid())
  userId       String?
  userEmail    String?
  userPhone    String?
  templateKey  String
  channel      NotificationChannel
  status       NotificationStatus
  provider     String?
  providerRef  String?
  payload      Json?
  error        String?
  createdAt    DateTime            @default(now())

  @@index([userId, createdAt])
  @@index([templateKey, createdAt])
  @@map("notification_logs")
}

model NotificationPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderUpdates     Boolean  @default(true)
  deliveryUpdates  Boolean  @default(true)
  weeklyDigest     Boolean  @default(true)
  morningPush      Boolean  @default(true)
  nudges           Boolean  @default(true)
  marketing        Boolean  @default(false)
  whatsappEnabled  Boolean  @default(true)
  emailEnabled     Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  eveningRecap     Boolean  @default(true)

  @@map("notification_preferences")
}
enum PartnerType {
  CUSTOMER
  GYM
  TRAINER
  INFLUENCER
  DIETICIAN
  DOCTOR
  CORPORATE
  RESIDENCE
}

enum PartnerStatus {
  PENDING
  ACTIVE
  PAUSED
  REJECTED
  TERMINATED
}

enum PartnerRewardType {
  CREDIT
  CASH
  MEAL_VOUCHER
  DISCOUNT_ONLY
  HYBRID
}

enum ReferralStatus {
  CLICKED
  SIGNED_UP
  FIRST_ORDER
  REWARD_PAID
  CANCELLED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

model Partner {
  id                 String              @id @default(cuid())
  type               PartnerType
  status             PartnerStatus       @default(PENDING)

  name               String
  contactEmail       String?
  contactPhone       String?

  // The user that "owns" this partner (logs in to see their dashboard).
  // For CUSTOMER: same as the customer user. For others: their FitFuel account.
  ownerUserId        String?             @unique
  ownerUser          User?               @relation("PartnerOwner", fields: [ownerUserId], references: [id])

  // Tracking
  code               String              @unique
  customLandingSlug  String?             @unique

  // Reward config (per-partner, set by admin)
  rewardType         PartnerRewardType
  rewardValueRs      Int                 @default(0)
  refereeDiscountRs  Int                 @default(0)

  // Type-specific fields (nullable, only set when relevant)
  // GYM
  gymAddress         String?
  gymManagerName     String?
  // TRAINER / INFLUENCER
  bio                String?
  specialty          String?
  profilePhotoUrl    String?
  socialHandle       String?
  followerCount      Int?
  // DIETICIAN / DOCTOR
  qualification      String?
  registrationNumber String?
  clinicName         String?
  credentialDocUrl   String?
  hospitalAffiliation String?
  // CORPORATE
  companyLogoUrl     String?
  allowedEmailDomain String?
  hrContactName      String?
  // RESIDENCE
  treasurerContact   String?
  societyAddress     String?

  // Tax/payout (schema only \u2014 admin UI deferred to 17C)
  panNumber          String?
  gstNumber          String?
  bankAccountName    String?
  bankAccountNumber  String?
  bankIfsc           String?

  // Admin
  adminNotes         String?
  internalLabel      String?
  createdById        String?
  approvedAt         DateTime?
  approvedById       String?

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  referrals          PartnerReferral[]
  payouts            PartnerPayout[]

  @@index([type, status])
  @@index([code])
  @@map("partners")
}

model PartnerReferral {
  id              String              @id @default(cuid())
  partnerId       String
  partner         Partner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  refereeUserId   String?
  refereeUser     User?               @relation("ReferralReferee", fields: [refereeUserId], references: [id])
  refereeOrderId  String?
  refereeOrder    Order?              @relation("ReferralOrder", fields: [refereeOrderId], references: [id])

  status          ReferralStatus      @default(SIGNED_UP)

  // Snapshot of reward at time of trigger
  rewardType      PartnerRewardType
  rewardAmountRs  Int                 @default(0)

  payoutId        String?

  createdAt       DateTime            @default(now())
  rewardEarnedAt  DateTime?

  @@index([partnerId, status])
  @@index([refereeUserId])
  @@map("partner_referrals")
}

model PartnerPayout {
  id                String         @id @default(cuid())
  partnerId         String
  partner           Partner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  periodYearMonth   String
  amountRs          Int
  referralCount     Int            @default(0)

  status            PayoutStatus   @default(PENDING)
  paidAt            DateTime?
  paymentRef        String?

  createdAt         DateTime       @default(now())

  @@unique([partnerId, periodYearMonth])
  @@map("partner_payouts")
}

model CreditLedger {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation("UserCredits", fields: [userId], references: [id], onDelete: Cascade)

  deltaRs         Int
  reason          String
  refReferralId   String?
  refOrderId      String?

  createdAt       DateTime      @default(now())

  @@index([userId, createdAt])
  @@map("credit_ledger")
}

model SupplementCategory {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  description  String?
  emoji        String?
  accentColor  String?
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)

  supplements  Supplement[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("supplement_categories")
}

model Supplement {
  id                String              @id @default(cuid())
  slug              String              @unique
  name              String
  brandName         String?

  // ── Educational content (preserves rich data from static file) ──
  aka               String[]
  tagline           String?
  description       String?             @db.Text
  mechanism         String?             @db.Text
  benefits          String[]
  dosage            String?
  timing            String?
  onsetTime         String?
  halfLife          String?
  form              String?
  cyclingRequired   Boolean             @default(false)
  cyclingProtocol   String?
  stacksWith        String[]
  avoidWith         String[]
  warnings          String?             @db.Text
  sideEffects       String[]
  genderNotes       String?             @db.Text
  ageNotes          String?             @db.Text

  // ── Evidence ──
  evidenceLevel     String?   // "very_high" | "high" | "moderate" | "low" | "preliminary"
  studyCount        String?
  keyStudyFindings  String[]

  // ── Commercial / display ──
  priceRange        String?   // display only — real prices live on SupplementLink rows
  valueRating       String?   // "exceptional" | "good" | "moderate" | "expensive"
  veganFriendly     Boolean   @default(false)
  certificationNote String?   @db.Text
  popular           Boolean   @default(false)
  indiaAvailability String?
  indiaNote         String?   @db.Text

  imageUrl          String?
  emoji             String?
  accentColor       String?

  // ── Targeting (multi-goal: a Whey Isolate serves MUSCLE_GAIN + BALANCED) ──
  recommendedFor    SupplementGoal[]

  categoryId        String
  category          SupplementCategory  @relation(fields: [categoryId], references: [id])

  sortOrder         Int                 @default(0)
  isFeatured        Boolean             @default(false)
  isActive          Boolean             @default(true)

  links             SupplementLink[]
  clicks            SupplementClick[]

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([categoryId, isActive])
  @@map("supplements")
}

model SupplementLink {
  id              String              @id @default(cuid())
  supplementId    String
  supplement      Supplement          @relation(fields: [supplementId], references: [id], onDelete: Cascade)

  network         AffiliateNetwork
  merchantLabel   String?             // override label, used when network=OTHER (e.g. "iHerb")
  affiliateUrl    String              @db.Text
  priceRs         Int?
  mrpRs           Int?
  notes           String?             // "1kg pack, 30 servings"

  sortOrder       Int                 @default(0)
  isActive        Boolean             @default(true)

  clicks          SupplementClick[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([supplementId, isActive])
  @@map("supplement_links")
}

model SupplementClick {
  id              String              @id @default(cuid())
  userId          String?
  user            User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  supplementId    String
  supplement      Supplement          @relation(fields: [supplementId], references: [id], onDelete: Cascade)
  linkId          String
  link            SupplementLink      @relation(fields: [linkId], references: [id], onDelete: Cascade)
  network         AffiliateNetwork
  referrer        String?             @db.Text
  ipHash          String?             // hashed for privacy — never raw IP
  userAgent       String?             @db.Text

  createdAt       DateTime            @default(now())

  @@index([supplementId, createdAt])
  @@index([linkId, createdAt])
  @@index([userId, createdAt])
  @@map("supplement_clicks")
}