// ============================================================
// FITFUEL — PRISMA SCHEMA v6.1 (Phase 9 — Recipe + Plan System)
// UPDATED: May 20, 2026 — Fixes 4 critical gaps from v6.0
//
// CHANGES IN THIS VERSION:
// 1. FoodEntry + MealLog: bidirectional relation (mealLogId back-ref)
// 2. MealPlan + MealPlanProduct: bridge relation + MealPlan.planPrices
// 3. PlanPrice: dual-link (productId legacy + mealPlanId new)
// 4. UserActivePlan: order relation + duration/mealsPerDay fields
// 5. Order: userActivePlans back-relation
//
// MIGRATION NAME: fix-phase9-relations-and-pricing-bridge
// Run: npx prisma migrate dev --name fix-phase9-relations-and-pricing-bridge
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  CUSTOMER
  ADMIN
  OWNER
}

enum DietType {
  VEGETARIAN
  EGGETARIAN
  NON_VEGETARIAN
}

enum MealPlanType {
  // ── Phase 3 — Core (live at launch) ──
  MUSCLE_GAIN
  WEIGHT_LOSS
  BALANCED_DIET
  OFFICE_EMPLOYEE
  JAIN_DIET
  // ── Phase 9 — Lifestyle & Medical (coming soon) ──
  HEALTHY_SEX_LIFESTYLE
  ALCOHOL_RECOVERY
  SMOKING_RECOVERY
  DIABETES_MANAGEMENT
  PCOS_HORMONAL_BALANCE
  THYROID_SUPPORT
  HYPERTENSION_DASH
  POST_SURGERY_RECOVERY
  MENTAL_HEALTH_STRESS
  GUT_HEALTH_IBS
  ANTI_AGING_LONGEVITY
  CUSTOM_PERSONALIZED
}

enum PlanDuration {
  TRIAL_DAY
  WEEKLY
  BI_WEEKLY
  MONTHLY_EXCL_WEEKENDS
  ONE_MONTH
  TWO_MONTH
  THREE_MONTH
}

enum MealsPerDay {
  BREAKFAST_LUNCH
  SNACK_DINNER
  ALL_FOUR
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_FAILED
  CONFIRMED
  PROCESSING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  PAYU
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  PREPARING
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED_DELIVERY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ActivityLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
  EXTREMELY_ACTIVE
}

enum FitnessGoal {
  LOSE_WEIGHT
  GAIN_MUSCLE
  MAINTAIN
  IMPROVE_FITNESS
  MANAGE_CONDITION
}

// ── Phase 9 — New Enums ──

enum MealSlot {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum PlanTier {
  STANDARD
  PREMIUM
  LUXURY
}

enum PlanCategory {
  STANDARD
  LIFESTYLE_MEDICAL
  SPORTS
  CORPORATE
  DIGITAL
}

enum DietVariant {
  VEG
  EGG
  NON_VEG
  JAIN
  VEGAN
}

enum DeliveryWindow {
  MORNING
  EVENING
}

// ============================================================
// USER
// ============================================================

model User {
  id            String    @id @default(cuid())
  phone         String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  avatarUrl     String?
  role          Role      @default(CUSTOMER)
  isActive      Boolean   @default(true)
  referralCode  String?   @unique // generated on signup
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile     UserProfile?
  addresses   Address[]
  orders      Order[]
  bodyMetrics BodyMetric[]
  activePlans ActivePlan[]
  accounts    Account[]
  sessions    Session[]

  // ── Phase 6 — Nutrition Tracker ──
  foodItems     FoodItem[]
  foodEntries   FoodEntry[]
  nutritionGoal NutritionGoal?
  waterLogs     WaterLog[]

  // ── Phase 7 — Exercise Library ──
  workoutSessions WorkoutSession[]

  // ── Phase 9 — Plan System ──
  userActivePlans UserActivePlan[]
  mealLogs        MealLog[]

  consistencySnapshots ConsistencySnapshot[]

  @@map("users")
}

model UserProfile {
  id             String         @id @default(cuid())
  userId         String         @unique
  dateOfBirth    DateTime?
  gender         Gender?
  heightCm       Float?
  weightKg       Float?
  activityLevel  ActivityLevel?
  fitnessGoal    FitnessGoal?
  dietPreference DietType?
  medicalNotes   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // ── Phase 9 — Onboarding + Personalisation fields ──
  targetWeightKg      Float?
  age                 Int?
  healthConditions    String[] // pcos, diabetic, thyroid, heart, etc.
  dietaryRestrictions String[] // no_pork, no_beef, nut_allergy, etc.
  allergies           String[] // nuts, dairy, gluten, shellfish
  tdee                Int? // computed + stored after onboarding
  calorieTarget       Int? // personalised target (= TDEE ± goal adjustment)
  onboardingComplete  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  weeklyConsistencyScore Int? // 0-100, recomputed every Sunday — feeds AI trainer
  referredBy             String? // userId of referrer

  @@map("user_profiles")
}

// ============================================================
// ADDRESS
// ============================================================

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  line1     String
  line2     String?
  area      String
  city      String   @default("Pune")
  pincode   String
  landmark  String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ============================================================
// MEAL PLAN PRODUCT (catalogue — Phase 3, preserved)
// DEPRECATED: Migrate checkout to MealPlan + PlanPrice directly.
// Kept for backward compatibility during transition.
// ============================================================

model MealPlanProduct {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  planType    MealPlanType
  description String?
  imageUrl    String?
  isActive    Boolean      @default(true)
  isLive      Boolean      @default(false)
  phase       Int          @default(3)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  pricing     PlanPrice[]
  orderItems  OrderItem[]
  activePlans ActivePlan[]
  mealPlans   MealPlan[] // ← NEW: bridge to Phase 9 MealPlan

  @@map("meal_plan_products")
}

// ============================================================
// PRICE TABLE
// ============================================================
// Dual-link: productId = legacy (MealPlanProduct), mealPlanId = new (MealPlan)
// During transition, populate both. Eventually drop productId + diet fields.
// ============================================================

model PlanPrice {
  id String @id @default(cuid())

  // Legacy link — MealPlanProduct (Phase 3)
  productId String?
  product   MealPlanProduct? @relation(fields: [productId], references: [id], onDelete: Cascade)

  // New link — MealPlan (Phase 9, 103 variants)
  mealPlanId String?
  mealPlan   MealPlan? @relation(fields: [mealPlanId], references: [id])

  diet        DietType
  duration    PlanDuration
  mealsPerDay MealsPerDay
  priceRs     Int
  gstPercent  Int          @default(5)
  isActive    Boolean      @default(true)

  mrpRs               Int?
  priceIsTaxInclusive Boolean @default(false)
  isDigital           Boolean @default(false)

  @@unique([productId, diet, duration, mealsPerDay])
  @@unique([mealPlanId, duration, mealsPerDay]) // ← NEW: unique for new plan pricing
  @@map("plan_prices")
}

// ============================================================
// ORDER
// ============================================================

model Order {
  id            String        @id @default(cuid())
  userId        String
  addressId     String?
  orderNumber   String        @unique
  status        OrderStatus   @default(PENDING_PAYMENT)
  subtotalRs    Int
  gstRs         Int
  totalRs       Int
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  payuTxnId     String?
  payuPaymentId String?
  notes         String?
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  address         Address?         @relation(fields: [addressId], references: [id])
  items           OrderItem[]
  deliveries      Delivery[]
  payment         Payment?
  userActivePlans UserActivePlan[] // ← NEW: link to active plan record

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  mrpSubtotalRs  Int?
  discountRs     Int     @default(0)
  couponCode     String?
  cgstRs         Int     @default(0)
  sgstRs         Int     @default(0)
  igstRs         Int     @default(0)
  buyerStateCode String?
  hsnSacCode     String?

  @@map("orders")
}

model OrderItem {
  id          String       @id @default(cuid())
  orderId     String
  productId   String?
  diet        DietType
  duration    PlanDuration
  mealsPerDay MealsPerDay
  priceRs     Int
  gstRs       Int
  totalRs     Int
  quantity    Int          @default(1)

  order   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product MealPlanProduct? @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ============================================================
// PAYMENT
// ============================================================

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amountRs      Int
  payuTxnId     String?
  payuPaymentId String?
  payuHash      String?
  rawResponse   Json?
  failureReason String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ============================================================
// DELIVERY
// ============================================================

model Delivery {
  id             String          @id @default(cuid())
  orderId        String
  deliveryDate   DateTime
  status         DeliveryStatus  @default(PREPARING)
  mealsIncluded  String[]
  driverName     String?
  driverPhone    String?
  trackingNotes  String?
  deliveredAt    DateTime?
  deliveryWindow DeliveryWindow?

  // ── Phase 10 — driver assignment + customer confirmation ──
  assignedDriverId    String?
  customerConfirmedAt DateTime? // customer tapped "Yes, received"
  customerIssueNote   String? // set when customer reports a problem

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver Driver? @relation(fields: [assignedDriverId], references: [id])

  @@index([orderId])
  @@index([deliveryDate])
  @@index([assignedDriverId])
  @@map("deliveries")
}

model ConsistencySnapshot {
  id             String   @id @default(cuid())
  userId         String
  weekStart      DateTime @db.Date
  score          Int
  label          String
  mealsPoints    Int      @default(0)
  workoutsPoints Int      @default(0)
  waterPoints    Int      @default(0)
  weighInPoints  Int      @default(0)
  noSkipPoints   Int      @default(0)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
  @@map("consistency_snapshots")
}

// ── Phase 10 — delivery drivers (tokenized-link access; franchiseId reserved for franchise model) ──
model Driver {
  id          String   @id @default(cuid())
  name        String
  phone       String
  accessToken String   @unique // tokenized-link auth — opens /driver/[accessToken]
  isActive    Boolean  @default(true)
  franchiseId String? // null = main Pune kitchen; set per-franchise later
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deliveries Delivery[]

  @@index([accessToken])
  @@index([franchiseId])
  @@map("drivers")
}

// ============================================================
// ACTIVE PLAN (Phase 3 — DEPRECATED)
// ============================================================
// Kept for backward compatibility. Migrate existing rows to
// UserActivePlan, then drop this table in a future migration.
// ============================================================

model ActivePlan {
  id          String       @id @default(cuid())
  userId      String
  productId   String
  diet        DietType
  duration    PlanDuration
  mealsPerDay MealsPerDay
  startDate   DateTime
  endDate     DateTime
  isPaused    Boolean      @default(false)
  pausedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user    User            @relation(fields: [userId], references: [id])
  product MealPlanProduct @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([endDate])
  @@map("active_plans")
}

// ============================================================
// BODY METRICS
// ============================================================

model BodyMetric {
  id           String   @id @default(cuid())
  userId       String
  measuredAt   DateTime @default(now())
  weightKg     Float?
  bmi          Float?
  bodyFatPct   Float?
  muscleMassKg Float?
  waterPct     Float?
  boneMassKg   Float?
  visceralFat  Float?
  metabolicAge Int?
  proteinPct   Float?
  source       String   @default("manual")
  notes        String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([measuredAt])
  @@map("body_metrics")
}

// ============================================================
// PHASE 7 — EXERCISE LIBRARY
// ============================================================

model Exercise {
  id               String   @id
  name             String
  category         String
  level            String
  force            String?
  mechanic         String?
  equipment        String?
  primaryMuscles   String[]
  secondaryMuscles String[]
  instructions     String[]
  images           String[]

  workoutExercises WorkoutExercise[]

  @@index([category])
  @@index([level])
  @@index([equipment])
  @@map("exercises")
}

model WorkoutSession {
  id             String    @id @default(cuid())
  userId         String
  name           String?
  date           DateTime  @db.Date
  startedAt      DateTime?
  completedAt    DateTime?
  durationMins   Int?
  caloriesBurned Int?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]

  @@index([userId, date])
  @@map("workout_sessions")
}

model WorkoutExercise {
  id               String  @id @default(cuid())
  workoutSessionId String
  exerciseId       String
  orderInSession   Int
  notes            String?

  workoutSession WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exercise       Exercise       @relation(fields: [exerciseId], references: [id])
  sets           WorkoutSet[]

  @@map("workout_exercises")
}

model WorkoutSet {
  id                String  @id @default(cuid())
  workoutExerciseId String
  setNumber         Int
  reps              Int?
  weightKg          Float?
  durationSecs      Int?
  distanceM         Float?
  completed         Boolean @default(false)
  notes             String?

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@map("workout_sets")
}

// ============================================================
// ADMIN NOTES
// ============================================================

model AdminNote {
  id        String   @id @default(cuid())
  userId    String
  authorId  String
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("admin_notes")
}

// ============================================================
// NEXTAUTH
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================================
// PHASE 6 — NUTRITION TRACKER
// ============================================================

model MealType {
  id        String      @id @default(cuid())
  name      String      @unique
  emoji     String?
  sortOrder Int         @default(0)
  entries   FoodEntry[]

  @@map("meal_types")
}

model FoodItem {
  id             String   @id @default(cuid())
  name           String
  brand          String?
  category       String?
  per100Calories Float
  per100Protein  Float    @default(0)
  per100Carbs    Float    @default(0)
  per100Fat      Float    @default(0)
  per100Fiber    Float    @default(0)
  isCustom       Boolean  @default(false)
  userId         String?
  createdAt      DateTime @default(now())

  entries FoodEntry[]
  user    User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Phase 9 — Recipe system back-relation ──
  recipeIngredients RecipeIngredient[]

  @@index([name])
  @@map("food_items")
}

model FoodEntry {
  id         String   @id @default(cuid())
  userId     String
  foodItemId String
  mealTypeId String
  entryDate  DateTime @db.Date
  quantity   Float
  calories   Float
  protein    Float
  carbs      Float
  fat        Float
  fiber      Float    @default(0)
  notes      String?
  createdAt  DateTime @default(now())

  // ── Phase 9 FIX: back-reference to MealLog ──
  // null = manually logged entry; set = auto-created from MealLog confirmation
  mealLogId String?  @unique
  mealLog   MealLog? @relation(fields: [mealLogId], references: [id])

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItem FoodItem @relation(fields: [foodItemId], references: [id])
  mealType MealType @relation(fields: [mealTypeId], references: [id])

  @@index([userId, entryDate])
  @@map("food_entries")
}

model NutritionGoal {
  id        String   @id @default(cuid())
  userId    String   @unique
  calories  Float    @default(2000)
  protein   Float    @default(150)
  carbs     Float    @default(250)
  fat       Float    @default(67)
  fiber     Int      @default(28)
  waterMl   Int      @default(2500)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("nutrition_goals")
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  entryDate DateTime @db.Date
  amountMl  Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryDate])
  @@map("water_logs")
}

// ============================================================
// PHASE 9A — RECIPE DATABASE
// ============================================================

// Core unit of the platform. Every meal, every plan, every PDF, every SOP.
model Recipe {
  id               String     @id @default(cuid())
  name             String
  slug             String     @unique
  description      String
  shortDescription String // one-line tagline for cards
  cuisineType      String // NorthIndian, SouthIndian, Continental, etc.
  mealType         MealSlot // BREAKFAST, LUNCH, DINNER, SNACK
  dietaryTags      String[] // VEG, EGG, NON_VEG, JAIN, VEGAN
  planCategories   String[] // weight_loss, pcos, diabetic, sports_strength, etc.
  tierAvailability PlanTier[] // STANDARD, PREMIUM, LUXURY
  servingSizeGrams Int // canonical serving size in grams
  prepTimeMins     Int
  cookTimeMins     Int
  difficulty       String // easy, medium, hard
  equipmentNeeded  String[]
  allergens        String[]
  shelfLifeHours   Int // how long after cooking
  packagingType    String // box, container, pouch
  kitchenStation   String // hot_kitchen, cold_prep, assembly
  costPerServing   Decimal? // ingredient cost — for margin tracking
  seasonTags       String[] // monsoon, summer, winter, all_year
  rotationGroup    Int // 1-60 — ensures no repeat in 60-day cycle
  imageUrl         String?
  videoUrl         String?
  isActive         Boolean    @default(true)
  isFeatured       Boolean    @default(false)
  swapAwayCount    Int        @default(0) // incremented on meal swap request
  avgRating        Float? // recomputed from MealLog ratings

  // Macros — per canonical serving
  caloriesPerServing Int
  proteinGrams       Decimal
  carbsGrams         Decimal
  fatGrams           Decimal
  fibreGrams         Decimal

  // Macros — per 100g (computed + stored for fast lookup)
  caloriesPer100g Int
  proteinPer100g  Decimal
  carbsPer100g    Decimal
  fatPer100g      Decimal
  fibrePer100g    Decimal

  // Micronutrients per serving — key ones for medical plans
  ironMg          Decimal?
  calciumMg       Decimal?
  vitaminDMcg     Decimal?
  vitaminCMg      Decimal?
  vitaminB12Mcg   Decimal?
  folateMcg       Decimal?
  sodiumMg        Decimal?
  potassiumMg     Decimal?
  omegaThreeGrams Decimal?
  zincMg          Decimal?
  magnesiumMg     Decimal?
  seleniumMcg     Decimal?
  glycaemicIndex  Int? // critical for diabetic + PCOS plans

  ingredients   RecipeIngredient[]
  steps         RecipeStep[]
  scheduleSlots PlanScheduleSlot[]
  mealLogs      MealLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mealType])
  @@index([rotationGroup])
  @@map("recipes")
}

// Links a recipe to a food_item. Quantities in raw grams.
model RecipeIngredient {
  id                 String  @id @default(cuid())
  recipeId           String
  foodItemId         String
  quantityGrams      Decimal // raw weight before cooking
  cookedWeightFactor Decimal @default(1.0) // cooked/raw ratio — rice: 2.5, chicken: 0.75
  prepNote           String? // "soaked overnight", "finely chopped", "boiled"
  isOptional         Boolean @default(false)
  substituteFor      String? // ingredient id this can replace
  orderInRecipe      Int

  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  foodItem FoodItem @relation(fields: [foodItemId], references: [id])

  @@map("recipe_ingredients")
}

// Step-by-step SOP — scales to franchise kitchen.
model RecipeStep {
  id           String  @id @default(cuid())
  recipeId     String
  stepNumber   Int
  title        String // "Marinate the chicken"
  instruction  String // full instruction text
  durationMins Int?
  temperatureC Int? // for baking/cooking temp
  technique    String? // "saute", "steam", "grill", "blend"
  kitchenNote  String? // note for kitchen staff only
  imageUrl     String?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_steps")
}

// ============================================================
// PHASE 9A — MEAL PLAN SYSTEM
// ============================================================

// Plan definition — the full catalogue of FitFuel plans.
model MealPlan {
  id                String       @id @default(cuid())
  name              String
  slug              String       @unique
  category          PlanCategory // STANDARD, LIFESTYLE_MEDICAL, SPORTS
  subCategory       String // weight_loss, pcos, diabetic, strength, etc.
  displayName       String // "Weight Loss — Non Vegetarian"
  tagline           String
  description       String
  longDescription   String // full sales page description
  whoIsItFor        String // target customer description
  keyPrinciples     String[] // nutritional principles bullet points
  whatIsAvoided     String[] // excluded ingredients / foods
  dietaryVariant    DietVariant // VEG, EGG, NON_VEG, JAIN, VEGAN
  tier              PlanTier // STANDARD, PREMIUM, LUXURY
  avgCaloriesPerDay Int
  avgProteinGrams   Int
  avgCarbsGrams     Int
  avgFatGrams       Int
  cycleLengthDays   Int          @default(30) // 30-day no-repeat
  mealsPerDay       Int          @default(4) // B+L+D+S
  nutritionistName  String?
  nutritionistCred  String? // "MSc Nutrition, RD"
  nutritionistBio   String?
  medicalDisclaimer String? // for lifestyle / medical plans
  isActive          Boolean      @default(false) // flip to true when ready to sell
  isFeatured        Boolean      @default(false)
  sortOrder         Int          @default(0)
  imageUrl          String?
  accentColor       String? // hex — for plan page theming

  // Links to legacy pricing (MealPlanProduct) for checkout compatibility
  productId String?
  product   MealPlanProduct? @relation(fields: [productId], references: [id])

  scheduleSlots   PlanScheduleSlot[]
  userActivePlans UserActivePlan[]
  planPrices      PlanPrice[] // ← NEW: direct pricing links

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([subCategory])
  @@map("meal_plans")
}

// 30-day rotating schedule. Day → Meal Slot → Recipe.
model PlanScheduleSlot {
  id                String   @id @default(cuid())
  mealPlanId        String
  dayNumber         Int // 1–60
  mealSlot          MealSlot // BREAKFAST, LUNCH, DINNER, SNACK
  recipeId          String
  servingMultiplier Decimal  @default(1.0) // adjust portion for this slot

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation(fields: [recipeId], references: [id])

  @@unique([mealPlanId, dayNumber, mealSlot])
  @@index([mealPlanId, dayNumber])
  @@map("plan_schedule_slots")
}

// Tracks which plan a user is on and which day they're currently on.
model UserActivePlan {
  id             String         @id @default(cuid())
  userId         String
  mealPlanId     String
  orderId        String?
  startDate      DateTime
  endDate        DateTime
  currentDay     Int            @default(1) // auto-increments daily
  status         String         @default("active") // active, paused, completed, cancelled
  pausedUntil    DateTime?
  skipDates      DateTime[] // dates user skipped delivery
  calorieTarget  Int? // personalised — overrides plan default
  proteinTarget  Int?
  carbTarget     Int?
  fatTarget      Int?
  deliveryWindow DeliveryWindow @default(MORNING)

  // ── NEW: denormalised from Order for fast dashboard queries ──
  duration    PlanDuration?
  mealsPerDay MealsPerDay?

  // ── NEW: proper relation to Order ──
  order Order? @relation(fields: [orderId], references: [id])

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealPlan MealPlan  @relation(fields: [mealPlanId], references: [id])
  mealLogs MealLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([endDate])
  isDigital Boolean @default(false)

  @@map("user_active_plans")
}

// Did the user eat today's planned meal? Links plan → nutrition tracker.
model MealLog {
  id               String    @id @default(cuid())
  userId           String
  userActivePlanId String
  recipeId         String
  mealSlot         MealSlot
  logDate          DateTime  @db.Date
  plannedGrams     Int // what the plan prescribed
  actualGrams      Int? // what user actually ate (adjusted)
  confirmedAt      DateTime? // when user tapped "I ate this"
  skipped          Boolean   @default(false)
  rating           Int? // 1-5 meal feedback
  ratingNote       String?

  // ── Phase 9 FIX: bidirectional relation to FoodEntry ──
  // MealLog creates FoodEntry → FoodEntry stores mealLogId as back-reference
  foodEntry FoodEntry?

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  activePlan UserActivePlan @relation(fields: [userActivePlanId], references: [id])
  recipe     Recipe         @relation(fields: [recipeId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, logDate])
  @@index([userActivePlanId])
  @@map("meal_logs")
}

// ============================================================
// PHASE 9D — EXERCISE SCHEDULE (linked to plan categories)
// ============================================================

// Workout program linked to a meal plan type / category.
model ExerciseSchedule {
  id                  String   @id @default(cuid())
  mealPlanCategory    String // weight_loss, muscle_gain, pcos, etc.
  tier                PlanTier
  name                String // "Weight Loss 5-Day Program"
  description         String
  weeklyStructure     Json // { mon: ["chest", "triceps"], tue: ["cardio"], ... }
  daysPerWeek         Int
  sessionDurationMins Int

  workoutDays ExerciseScheduleDay[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mealPlanCategory])
  @@map("exercise_schedules")
}

model ExerciseScheduleDay {
  id                String  @id @default(cuid())
  scheduleId        String
  dayOfWeek         String // monday, tuesday, ... or rest
  focusArea         String // "Upper body strength", "LISS Cardio", "Rest + Mobility"
  exercises         Json // [{ exerciseId, sets, reps, restSecs, notes }]
  estimatedCalories Int
  isRestDay         Boolean @default(false)

  schedule ExerciseSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@map("exercise_schedule_days")
}

enum DiscountType {
  PERCENT
  FLAT
  FREE_DELIVERY
}

enum CouponSource {
  MANUAL
  REFERRAL
  CART_RECOVERY
  LOYALTY
}

model Coupon {
  id                String             @id @default(cuid())
  code              String             @unique
  discountType      DiscountType
  value             Int
  maxDiscountRs     Int?
  minOrderRs        Int?
  appliesTo         String             @default("ALL")
  firstOrderOnly    Boolean            @default(false)
  usageLimitGlobal  Int?
  usageLimitPerUser Int?               @default(1)
  validFrom         DateTime?
  validUntil        DateTime?
  stackable         Boolean            @default(false)
  source            CouponSource       @default(MANUAL)
  isActive          Boolean            @default(true)
  redemptions       CouponRedemption[]
  createdAt         DateTime           @default(now())

  @@map("coupons")
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  orderId   String
  amountRs  Int
  createdAt DateTime @default(now())

  @@index([couponId, userId])
  @@map("coupon_redemptions")
}
