## PHASE 9L — NET CALORIE ENGINE

### How It Works

```typescript
// lib/netCalories.ts
export async function getDailyCalorieBalance(userId: string, date: Date) {
  // Calories IN — from MealLog (plan meals confirmed) + FoodEntry (manual)
  const mealLogCalories = await getMealLogCalories(userId, date)
  const manualCalories = await getNutritionDiaryCalories(userId, date)
  const totalIn = mealLogCalories + manualCalories

  // Calories OUT — from WorkoutSession
  const caloriesBurned = await getWorkoutCalories(userId, date)

  // Target — from UserActivePlan or UserProfile
  const target = await getCalorieTarget(userId)

  return {
    in: totalIn,
    out: caloriesBurned,
    net: totalIn - caloriesBurned,
    target,
    remaining: target - (totalIn - caloriesBurned),
    status: totalIn - caloriesBurned < target ? 'under' : 'over'
  }
}
```

